{
  "uid": "scan2serve-clickhouse",
  "title": "Scan2Serve - ClickHouse Overview",
  "tags": ["scan2serve", "clickhouse", "database"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Query Rate (QPS)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_Query[1m])",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Select vs Insert QPS",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_SelectQuery[1m])",
          "legendFormat": "select"
        },
        {
          "refId": "B",
          "expr": "rate(ClickHouseProfileEvents_InsertQuery[1m])",
          "legendFormat": "insert"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Failed Query Rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_FailedQuery[5m])",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Avg Query Time (ms)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(ClickHouseProfileEvents_QueryTimeMicroseconds[5m]) / rate(ClickHouseProfileEvents_Query[5m])) / 1000",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "decimals": 2 },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Active Queries",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "ClickHouseMetrics_Query",
          "legendFormat": "all"
        },
        {
          "refId": "B",
          "expr": "ClickHouseMetrics_QueryNonInternal",
          "legendFormat": "non-internal"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Background Merges",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "ClickHouseMetrics_Merge",
          "legendFormat": "merges"
        },
        {
          "refId": "B",
          "expr": "ClickHouseMetrics_MergeParts",
          "legendFormat": "parts"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Async Insert Rows /s",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_AsyncInsertRows[5m])",
          "legendFormat": "rows"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Async Insert Bytes /s",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 23 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ClickHouseProfileEvents_AsyncInsertBytes[5m])",
          "legendFormat": "bytes"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    }
  ]
}
