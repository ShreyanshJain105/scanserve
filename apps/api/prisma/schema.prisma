generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────

enum UserRole {
  customer
  business
  admin
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(customer)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  businesses    Business[]
  ownedOrgs     Org[]                      @relation("OrgOwner")
  orgMemberships OrgMembership[]
  orgInvites    OrgInvite[]
  businessMemberships BusinessMembership[]
  refreshTokens RefreshToken[]
  notifications NotificationEvent[]       @relation("NotificationEventUser")
  actedNotifications NotificationEvent[]  @relation("NotificationEventActor")
  inboxEntries   NotificationInbox[]
  

  @@map("users")
}

// ─── Business ───────────────────────────────────────────────

enum BusinessStatus {
  pending
  approved
  rejected
  archived
}

model Business {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  orgId       String?        @map("org_id")
  name        String
  slug        String         @unique
  currencyCode String        @default("USD") @map("currency_code")
  description String?
  logoUrl     String?        @map("logo_url")
  address     String
  phone       String
  status      BusinessStatus @default(pending)
  blocked     Boolean        @default(false)
  archivedAt  DateTime?      @map("archived_at")
  archivedPreviousStatus BusinessStatus? @map("archived_previous_status")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Org?       @relation(fields: [orgId], references: [id], onDelete: SetNull)
  categories Category[]
  menuItems  MenuItem[]
  tables     Table[]
  qrCodes    QrCode[]
  orders     Order[]
  memberships BusinessMembership[]
  rejections BusinessRejection[]
  updateRequests BusinessUpdateRequest[]
  notificationEvents NotificationEvent[]

  @@index([status, archivedAt])
  @@index([orgId])
  @@map("businesses")
}

enum BusinessUpdateRequestStatus {
  pending
  approved
  rejected
}

model BusinessUpdateRequest {
  id         String                       @id @default(cuid())
  businessId String                       @map("business_id")
  payload    Json
  status     BusinessUpdateRequestStatus  @default(pending)
  reviewNote String?                      @map("review_note")
  reviewedBy String?                      @map("reviewed_by")
  reviewedAt DateTime?                    @map("reviewed_at")
  createdAt  DateTime                     @default(now()) @map("created_at")
  updatedAt  DateTime                     @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@map("business_update_requests")
}

model NotificationEvent {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  actorUserId String?   @map("actor_user_id")
  businessId  String?   @map("business_id")
  type        String
  message     String
  payload     Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  user     User      @relation("NotificationEventUser", fields: [userId], references: [id], onDelete: Cascade)
  actor    User?     @relation("NotificationEventActor", fields: [actorUserId], references: [id])
  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inbox    NotificationInbox[]

  @@index([userId, createdAt])
  @@map("notification_events")
}

model NotificationInbox {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  eventId   String            @map("event_id")
  createdAt DateTime          @default(now()) @map("created_at")

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  event NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notification_inbox")
}

model BusinessRejection {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@map("business_rejections")
}

// ─── Menu ───────────────────────────────────────────────────

model Category {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  name       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@unique([businessId, name])
  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  businessId  String   @map("business_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imagePath   String?  @map("image_path")
  isAvailable Boolean  @default(true) @map("is_available")
  dietaryTags String[] @map("dietary_tags")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("menu_items")
}

// ─── Tables & QR ────────────────────────────────────────────

model Table {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  tableNumber Int      @map("table_number")
  label       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  qrCode   QrCode?
  orders   Order[]

  @@unique([businessId, tableNumber])
  @@map("tables")
}

model QrCode {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  tableId    String   @unique @map("table_id")
  uniqueCode String   @unique @map("unique_code")
  qrImageUrl String?  @map("qr_image_url")
  createdAt  DateTime @default(now()) @map("created_at")

  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  table     Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  rotations QrCodeRotation[]

  @@map("qr_codes")
}

model QrCodeRotation {
  id              String    @id @default(cuid())
  qrCodeId        String    @map("qr_code_id")
  oldToken        String    @unique @map("old_token")
  newToken        String    @map("new_token")
  rotatedByUserId String?   @map("rotated_by_user_id")
  reason          String?
  graceExpiresAt  DateTime? @map("grace_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  qrCode QrCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@index([qrCodeId, createdAt])
  @@index([graceExpiresAt])
  @@map("qr_code_rotations")
}

// ─── Orders ─────────────────────────────────────────────────

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum OrgInviteStatus {
  pending
  accepted
  declined
}

enum BusinessRole {
  owner
  manager
  staff
}

model Org {
  id          String   @id @default(cuid())
  ownerUserId String   @map("owner_user_id")
  name        String?  @db.VarChar(160)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       User            @relation("OrgOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  businesses  Business[]
  memberships OrgMembership[]
  invites     OrgInvite[]

  @@index([ownerUserId])
  @@map("orgs")
}

model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("org_memberships")
}

model OrgInvite {
  id          String          @id @default(cuid())
  orgId       String          @map("org_id")
  userId      String          @map("user_id")
  status      OrgInviteStatus @default(pending)
  createdAt   DateTime        @default(now()) @map("created_at")
  respondedAt DateTime?       @map("responded_at")

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("org_invites")
}

model Order {
  id              String        @id @default(cuid())
  businessId      String        @map("business_id")
  tableId         String        @map("table_id")
  status          OrderStatus   @default(pending)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  razorpayOrderId String?       @map("razorpay_order_id")
  razorpayPaymentId String?     @map("razorpay_payment_id")
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  customerName    String        @map("customer_name")
  customerPhone   String?       @map("customer_phone")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  table    Table       @relation(fields: [tableId], references: [id])
  items    OrderItem[]

  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@map("orders")
}

model BusinessMembership {
  id         String       @id @default(cuid())
  businessId String       @map("business_id")
  userId     String       @map("user_id")
  role       BusinessRole
  createdAt  DateTime     @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@map("business_memberships")
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String  @map("order_id")
  menuItemId          String  @map("menu_item_id")
  quantity            Int
  unitPrice           Decimal @map("unit_price") @db.Decimal(10, 2)
  specialInstructions String? @map("special_instructions")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

// ─── Auth Refresh Tokens ─────────────────────────────────────

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  tokenHash  String   @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([tokenHash])
  @@map("refresh_tokens")
}

// ─── Asset Cleanup Queue ────────────────────────────────────

enum DeletedAssetType {
  menu_item_image
  business_logo
}

enum DeletedAssetCleanupStatus {
  pending
  processing
  failed
  done
}

model DeletedAssetCleanup {
  id           String                    @id @default(cuid())
  assetType    DeletedAssetType          @map("asset_type")
  entityId     String                    @map("entity_id")
  s3Path       String                    @map("s3_path")
  status       DeletedAssetCleanupStatus @default(pending)
  attemptCount Int                       @default(0) @map("attempt_count")
  nextAttemptAt DateTime?                @map("next_attempt_at")
  lastError    String?                   @map("last_error")
  processedAt  DateTime?                 @map("processed_at")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  @@index([status, nextAttemptAt, createdAt])
  @@index([assetType, entityId])
  @@map("deleted_asset_cleanups")
}

model ArchivedBusinessDeletionAudit {
  id            String   @id @default(cuid())
  businessId    String   @map("business_id")
  userId        String   @map("user_id")
  name          String
  slug          String
  archivedAt    DateTime @map("archived_at")
  deletedAt     DateTime @default(now()) @map("deleted_at")
  retentionDays Int      @map("retention_days")
  metadata      Json?

  @@index([deletedAt])
  @@index([userId, deletedAt])
  @@map("archived_business_deletion_audits")
}
