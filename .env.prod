# Production environment variables
# Copy to .env.prod and fill all REQUIRED values.

# Image tags (optional)
TAG=latest
REGISTRY=

# Gateway port (optional)
GATEWAY_HTTP_PORT=80

# Postgres (REQUIRED)
POSTGRES_DB=scan2serve
POSTGRES_USER=scan2serve
POSTGRES_PASSWORD=kunika
POSTGRES_PORT=5432

# MinIO (REQUIRED if using bundled MinIO)
MINIO_ROOT_USER="bhavook"
MINIO_ROOT_PASSWORD="Bhavook||2"
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis (REQUIRED if using bundled Redis)
REDIS_PORT=6379

# ClickHouse (REQUIRED if using bundled ClickHouse)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9002
# REQUIRED: update clickhouse-users/admin.xml with a strong password before deployment.


# API runtime (REQUIRED)
DATABASE_URL="postgresql://scan2serve:kunika@db:5432/scan2serve"
JWT_SECRET="bhavook-kunika"
INTERNAL_API_KEY="kunika2"
# COOKIE_DOMAIN="scan2serve.com"
ADMIN_SEED_EMAIL="admin@scan2serve.com"
ADMIN_SEED_PASSWORD="Bhavook||2"

# Storage (REQUIRED if using bundled MinIO)
S3_ENDPOINT="http://minio:9000"
S3_PUBLIC_URL="http://localhost:9000"
# S3_PUBLIC_URL="https://scan2serve.com"
S3_REGION="us-east-1"
S3_BUCKET="scan2serve-menu-images"
S3_ACCESS_KEY="bhavook"
S3_SECRET_KEY="kunika"
S3_FORCE_PATH_STYLE=true

# Analytics + cache services (REQUIRED if using bundled services)
CLICKHOUSE_URL="http://clickhouse:8123"
CLICKHOUSE_DATABASE="scan2serve"
REDIS_URL="redis://redis:6379"

# Optional: split ClickHouse users
CLICKHOUSE_BOOTSTRAP_USER="admin_user"
CLICKHOUSE_BOOTSTRAP_PASSWORD="kunika"
CLICKHOUSE_INGEST_USER="admin_user"
CLICKHOUSE_INGEST_PASSWORD="kunika"
CLICKHOUSE_QUERY_USER="admin_user"
CLICKHOUSE_QUERY_PASSWORD="kunika"


# Optional: payments
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Optional: LLM providers
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
LLM_MENU_MODEL="gpt-4.1-mini"
LLM_MENU_TIMEOUT_MS=4500
GEMINI_API_KEY=""
GEMINI_API_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_IMAGE_MODEL="gemini-3-pro-image-preview"

# Feature flags (optional)
ENABLE_CUSTOMER_QR_AUTH=true
NEXT_PUBLIC_ENABLE_CUSTOMER_QR_AUTH=true


# Core URLs (REQUIRED)

NEXT_PUBLIC_API_URL="http://localhost"      # or http://localhost:3000 if gateway port is 3000
CLIENT_URL="http://localhost"
NEXT_PUBLIC_SITE_URL="http://localhost"
NEXT_PUBLIC_APP_URL="http://localhost"
COOKIE_DOMAIN=""



# CLIENT_URL="https://scan2serve.com"
# NEXT_PUBLIC_SITE_URL="https://scan2serve.com"
# NEXT_PUBLIC_APP_URL="https://app.scan2serve.com"
# # The public API base should point to the gateway origin
# NEXT_PUBLIC_API_URL="https://scan2serve.com"